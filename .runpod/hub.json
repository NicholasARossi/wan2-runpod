{
  "title": "Wan 2.2 I2V (Image-to-Video)",
  "description": "Wan 2.2 14B Image-to-Video generation with lightx2v 4-step acceleration and up to 4 custom LoRA pairs. Uses ComfyUI as the inference backend with fp8 quantized models baked into the image.",
  "type": "serverless",
  "category": "video",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 100,
    "gpuIds": [
      "NVIDIA GeForce RTX 4090",
      "NVIDIA RTX A5000",
      "NVIDIA L40",
      "NVIDIA L40S"
    ],
    "presets": [
      {
        "name": "Default (480x832, 8 steps)",
        "defaults": {
          "WIDTH": "480",
          "HEIGHT": "832",
          "STEPS": "8",
          "CFG": "2.0",
          "LENGTH": "81"
        }
      }
    ],
    "env": [
      {
        "key": "SERVER_ADDRESS",
        "value": "127.0.0.1"
      }
    ]
  }
}
